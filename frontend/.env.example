# Create React App — copy to .env.local for local dev, set in Vercel for production.

# Required in production (must end with /api):
REACT_APP_API_URL=https://smartspend-backend.onrender.com/api

# Local dev (optional — setupProxy.js handles /api without this):
# REACT_APP_API_URL=http://127.0.0.1:8002/api

# Optional: force CRA dev proxy target
# REACT_APP_PROXY_TARGET=http://127.0.0.1:8002

# Optional admin diagnostics unlock
# REACT_APP_ADMIN_TOKEN=
