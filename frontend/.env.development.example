# Local dev — usually leave REACT_APP_API_URL unset.
# The app calls /api and setupProxy.js forwards to the backend (auto-detects 8002, then 8001).

# Force proxy target if auto-detect fails:
# REACT_APP_PROXY_TARGET=http://127.0.0.1:8002

# Only for production-style local testing (bypasses proxy — not recommended for daily dev):
# REACT_APP_API_URL=http://127.0.0.1:8002/api
