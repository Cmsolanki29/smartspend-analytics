# ── Database (Neon / Supabase / local) ─────────────────────────────────────
# Preferred for production — paste from Neon dashboard:
DATABASE_URL=postgresql://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require

# Or split (local dev):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=smartspend_db
# DB_USER=postgres
# DB_PASSWORD=

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── CORS / frontend ────────────────────────────────────────────────────────
# Production Vercel URL (no trailing slash). Also add to CORS_ORIGINS if needed.
FRONTEND_URL=https://your-app.vercel.app
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── LLM APIs ───────────────────────────────────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional model overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash

# ── Redis (optional — app falls back to in-process bus) ─────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Phase flags (Render blueprint defaults GNN/DNN off) ─────────────────────
PHASE_9_AGENT_ENABLED=true
PHASE_10_GNN_ENABLED=false
PHASE_11_DNN_ENABLED=false
PHASE_11_DNN_PROMOTED=false
PHASE_12_ORCHESTRATOR_ENABLED=true

# ── Admin / demo ───────────────────────────────────────────────────────────
ADMIN_TOKEN=change-me-in-production
# ADMIN_USER_IDS=

# New signups: 0 = upload-first (production). 1 = auto-seed 1000+ demo txns.
SMARTSPEND_SEED_DEMO_TXNS=0

# OCR for scanned PDFs (optional; install tesseract on the host)
# TESSERACT_CMD=/usr/bin/tesseract
