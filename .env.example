# SmartSpend — copy to `.env` at project root (same folder as backend/ and frontend/).

# ── Database ─────────────────────────────────────────────────────────────────
# Production (Neon): paste full connection string
DATABASE_URL=postgresql://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require

# Local alternative:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=smartspend_db
# DB_USER=postgres
# DB_PASSWORD=your_password_here

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── Production URLs ──────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# CRA frontend build (Vercel):
# REACT_APP_API_URL=https://smartspend-backend.onrender.com/api

# ── LLM APIs ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Phase flags ──────────────────────────────────────────────────────────────
PHASE_9_AGENT_ENABLED=true
PHASE_10_GNN_ENABLED=false
PHASE_11_DNN_ENABLED=false
PHASE_11_DNN_PROMOTED=false
PHASE_12_ORCHESTRATOR_ENABLED=true

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_TOKEN=dev-admin-secret
# ADMIN_USER_IDS=

# Signup: 0 = upload-first (production). 1 = auto demo transactions.
SMARTSPEND_SEED_DEMO_TXNS=0

# Optional Redis
# REDIS_URL=redis://localhost:6379/0

# Local debugging only — never enable in production
# SMARTSPEND_DEBUG_AUTH=1
