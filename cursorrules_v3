# ================================================================
# RULE 4 — FRAUD DETECTION: GLOBAL RULES FOR ALL USERS
# ================================================================

## 4A — CONTAMINATION SETTING
#   IsolationForest(contamination=0.03)   ← use 0.03, NOT 0.06
#   Lower contamination = fewer forced outliers = fewer false positives
#   File: backend/services/ml_model.py (model initialisation line)

## 4B — MINIMUM THRESHOLD TO SET anomaly_flag
#   ONLY set anomaly_flag = True when BOTH conditions met:
#     (a) predict == -1  (IsolationForest says outlier)
#     (b) risk_score >= 50
#
#   Code (apply everywhere anomaly_flag is written to DB):
#     anomaly_flag = (predict == -1) and (risk_score >= 50)
#
#   If risk_score < 50 → anomaly_flag = False, even if model predicts -1

## 4C — MERCHANT TRUST RULE  (fixes Swiggy / Zomato false positives)
#   Before scoring ANY transaction, check merchant frequency:
#
#     merchant_key = normalize_merchant(transaction.merchant)
#     count_90d = SELECT COUNT(*) FROM transactions
#                 WHERE user_id = :uid
#                   AND normalized_merchant = :merchant_key
#                   AND amount < 0          -- debits only
#                   AND date >= NOW() - 90 days
#
#     if count_90d >= 5:
#         risk_score = min(risk_score, 30)
#         anomaly_flag = False
#
#   normalize_merchant function:
#     - lowercase
#     - strip punctuation and trailing numbers
#     - take first significant word
#     Examples:
#       "SWIGGY*ORDER123"    → "swiggy"
#       "Zomato Food Pvt"    → "zomato"
#       "AMAZON PAY 9283"    → "amazon"
#       "Netflix.com"        → "netflix"
#
#   Store normalized_merchant column in transactions table
#   Backfill on first run for existing users

## 4D — UI SEVERITY DISPLAY RULES  (Frontend — applies to ALL users)
#   risk_score >= 70 (HIGH/CRITICAL) → red badge   "Fraud Alert"
#   risk_score 50-69 (MEDIUM)        → yellow badge "Unusual Spend"
#   risk_score < 50  (LOW)           → NOT shown in alerts list
#                                       greyed/italic in transactions only
#
#   Label rules by alert type:
#     ML_ANOMALY   → "Unusual spend for you"   (never "Fraud Detected")
#     SCAM/PHISH   → "Fraud Alert"
#     RULE_BASED HIGH → "Suspicious Transaction"
#
#   NEVER show every anomaly_flag=True as a red scary alert

## 4E — ML MODEL: PER-USER STRICTLY
#   - Model dict keyed by user_id: models = { user_id: IsolationForest }
#   - Train only on this user's transactions
#   - Score only with this user's model
#   - Retrain trigger: upload complete AND user total debits >= 30
#   - If < 30 debits: store data, show "Building your baseline..." in UI
#   - Missing model → rule-based fallback, return { ml_ready: false }

## 4F — 9TH FEATURE: merchant_debit_count_90d
#   Add to feature vector as 9th feature:
#     log1p(count of same-merchant debits in past 90 days for this user)
#   This teaches the model: frequent merchant = lower anomaly score
#   Backfill when retraining existing users

## 4G — CATEGORY NORMALISATION (at parse time, for ALL uploads)
#   Normalise merchant → category BEFORE storing to DB.
#   This runs in the PARSER, not the upload handler — so it applies to
#   bank links, PDF uploads, CSV uploads, and credit card uploads equally.
#
#   CANONICAL MAP (case-insensitive, match on normalized_merchant prefix):
#     swiggy, zomato, eatsure, blinkit, zepto, bigbasket  → "Food"
#     amazon, flipkart, myntra, meesho, ajio, snapdeal     → "Shopping"
#     uber, ola, rapido, yulu, bounce                      → "Transport"
#     netflix, spotify, hotstar, primevideo, youtube premium → "Entertainment"
#     byju, unacademy, coursera, udemy, vedantu            → "Education"
#     1mg, pharmeasy, apollo pharmacy, medplus             → "Health"
#     irctc, makemytrip, yatra, goibibo, cleartrip         → "Travel"
#     phonepe, googlepay, paytm, gpay                      → "UPI Transfer"
#   Never store "MISC" if merchant is recognisable.
#   Parser location: backend/services/parser_utils.py → enrich_category()
#   Call enrich_category() on EVERY transaction before upsert to DB.


# ================================================================
